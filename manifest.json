{
    "manifest_version": 3,
    "name": "OmmNoMi Random Selection Utility",
    "version": "0.1",
    "description": "Premium tool to automate employee lists and select entries for random testing.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://labbreport.com/*",
                "*://*.labbreport.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "inject.css"
            ],
            "all_frames": true,
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "*://labbreport.com/*",
        "*://*.labbreport.com/*"
    ]
}