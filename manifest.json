{
    "manifest_version": 3,
    "name": "OmmNoMi Random Selection Utility",
    "version": "0.1",
    "description": "Premium tool to automate employee lists and select entries for random testing.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://labbreport.com/screener/organizationEmployee*",
                "https://labbreport.com/screener/labbPassport/create*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "inject.css"
            ]
        }
    ],
    "host_permissions": [
        "https://labbreport.com/*"
    ]
}